# Public browser URL for the Next.js application.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side URL used by Next.js to reach FastAPI. Do not expose secrets here.
API_URL=http://127.0.0.1:8000

# Comma-separated browser origins allowed to call FastAPI during development.
CORS_ORIGINS=http://localhost:3000

# Optional absolute directory that bounds all static repository scans.
# Empty uses the Sentinel repository root inferred from the backend source layout.
SENTINEL_SCAN_ROOT=
